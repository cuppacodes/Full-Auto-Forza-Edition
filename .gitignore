# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# PyInstaller artifacts
build/
dist/
*.spec

# Release distribution (built output — not source)
FAFE_dist/
FAFE v*/
FAFE.v*.zip
*.zip
build_*.log

# User local config (generated by build_app.bat into FAFE_dist/)
config.json

# Bug-report bundles (generated at runtime by report.py)
reports/

# runtime diagnostics
fafe_diag.log

# User-captured custom templates (never commit — user data, any language)
templates/**/custom/
